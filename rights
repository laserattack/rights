#!/usr/bin/env perl

use strict;
use warnings;
use feature qw\say switch\;

sub usage {
    say "What is it : Linux file permissions explainer";
    say "Usage      : rights PERMISSIONS";
    say "";
    say "Arguments:";
    say "  PERMISSIONS  File permissions in various formats:";
    say "               Symbolic : rwxr-xr-x, rw-------, r-x--x--x";
    say "               Numeric  : 755, 644, 777, 600, 444";
    say "";
    say "Examples:";
    say "  rights 755        Explain what 755 means";
    say "  rights rwxr-xr-x  Explain symbolic permissions";
}

sub explain_symbolic_perm {
    my ($perm) = @_;
    my $type   = $perm->{type} // '-';
    my $own_r  = $perm->{own_r};
    my $own_w  = $perm->{own_w};
    my $own_x  = $perm->{own_x};
    my $grp_r  = $perm->{grp_r};
    my $grp_w  = $perm->{grp_w};
    my $grp_x  = $perm->{grp_x};
    my $oth_r  = $perm->{oth_r};
    my $oth_w  = $perm->{oth_w};
    my $oth_x  = $perm->{oth_x};
    my $suffix = $perm->{suffix} // '';

    print "File type:           ";
    given ($type) {
        when ('-') { say "regular file" }
        when ('d') { say "directory" }
        when ('l') { say "symbolic link" }
        when ('p') { say "named pipe" }
        when ('c') { say "character device" }
        when ('b') { say "block device" }
        when ('s') { say "socket" }
        when ('')  { say "not specified" }
    }

    print "Owner permissions:   ";
    given ($own_r) {
        when ('r') { print "read, " }
        when ('-') { print "no read, " }
    }
    given ($own_w) {
        when ('w') { print "write, " }
        when ('-') { print "no write, " }
    }
    given ($own_x) {
        when ('x') { say "execute" }
        when ('s') { say "execute with suid (run as file owner)" }
        when ('S') { say "suid (run as file owner) set but no execute" }
        when ('-') { say "no execute" }
    }

    print "Group permissions:   ";
    given ($grp_r) {
        when ('r') { print "read, " }
        when ('-') { print "no read, " }
    }
    given ($grp_w) {
        when ('w') { print "write, " }
        when ('-') { print "no write, " }
    }
    given ($grp_x) {
        when ('x') { say "execute" }
        when ('s') { say "execute with sgid (run as group member)" }
        when ('S') { say "sgid (run as group member) set but no execute" }
        when ('-') { say "no execute" }
    }

    print "Others permissions:  ";
    given ($oth_r) {
        when ('r') { print "read, " }
        when ('-') { print "no read, " }
    }
    given ($oth_w) {
        when ('w') { print "write, " }
        when ('-') { print "no write, " }
    }
    given ($oth_x) {
        when ('x') { say "execute" }
        when ('t') { say "sticky bit (for directories: only owner or root can delete files)" }
        when ('T') { say "sticky bit (for directories: only owner or root can delete files) set but no execute" }
        when ('-') { say "no execute" }
    }

    print "Suffix:              ";
    given ($suffix) {
        when ('+') { say "ACL present (Access Control Lists)" }
        when ('.') { say "SELinux context present" }
        when ('')  { say "not specified" }
    }

    my $symbolic = $type.$own_r.$own_w.$own_x.$grp_r.$grp_w.$grp_x.$oth_r.$oth_w.$oth_x.$suffix;
    print "Symbolic:            $symbolic\n";
    
    print "Numeric:             ";
    my $own_num = 0;
    $own_num += 4 if $own_r eq 'r';
    $own_num += 2 if $own_w eq 'w';
    $own_num += 1 if $own_x =~ /[xsS]/;
    my $grp_num = 0;
    $grp_num += 4 if $grp_r eq 'r';
    $grp_num += 2 if $grp_w eq 'w';
    $grp_num += 1 if $grp_x =~ /[xsS]/;
    my $oth_num = 0;
    $oth_num += 4 if $oth_r eq 'r';
    $oth_num += 2 if $oth_w eq 'w';
    $oth_num += 1 if $oth_x =~ /[xtT]/;
    my $special = 0;
    $special += 4 if $own_x =~ /[sS]/;
    $special += 2 if $grp_x =~ /[sS]/;
    $special += 1 if $oth_x =~ /[tT]/;
    if ($special > 0) {
        printf "%d%d%d%d\n", $special, $own_num, $grp_num, $oth_num;
    } else {
        printf "%d%d%d\n", $own_num, $grp_num, $oth_num;
    }
}

sub explain_numeric_perm {
    my ($num) = @_;
    my ($special, $owner, $group, $other) = (0, 0, 0, 0);

    if (length($num) == 3) {
        ($owner, $group, $other) = split //, $num;
    } elsif (length($num) == 4) {
        ($special, $owner, $group, $other) = split //, $num;
    }

    my %perm = (
        type   => '',
        own_r  => ($owner & 4)? 'r': '-',
        own_w  => ($owner & 2)? 'w': '-',
        own_x  => ($owner & 1)? (($special & 4)? 's': 'x'): (($special & 4)? 'S': '-'),
        grp_r  => ($group & 4)? 'r': '-',
        grp_w  => ($group & 2)? 'w': '-',
        grp_x  => ($group & 1)? (($special & 2)? 's': 'x'): (($special & 2)? 'S': '-'),
        oth_r  => ($other & 4)? 'r': '-',
        oth_w  => ($other & 2)? 'w': '-',
        oth_x  => ($other & 1)? (($special & 1)? 't': 'x'): (($special & 1)? 'T': '-'),
        suffix => '',
    );

    explain_symbolic_perm(\%perm);
}

sub explain {
    my ($arg) = @_;
    if ($arg =~ /^[0-7]{3,4}$/) {
        explain_numeric_perm($arg);
    } elsif ($arg =~ /^([-dlscbp]?)([r-])([w-])([xsS-])([r-])([w-])([xsS-])([r-])([w-])([xtT-])([+\.]?)$/) {
        explain_symbolic_perm({
            type  => $1,
            own_r => $2, own_w => $3, own_x => $4,
            grp_r => $5, grp_w => $6, grp_x => $7,
            oth_r => $8, oth_w => $9, oth_x => $10,
            suffix => $11
        });
    } else {
        say "ERROR: Incorrect permissions format";
        usage();
        exit 1;
    }
}

sub main {
    for my $i (0..$#ARGV) {
        explain($ARGV[$i]);
        say "" if $i < $#ARGV;
    }
    exit 0;
}

unless (@ARGV) {
    usage();
    exit 1;
}

main();
