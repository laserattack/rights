#!/usr/bin/env perl

# What is it : Linux file permissions explainer
# Usage      : rights ARGUMENTS

use strict;
use warnings;
use feature 'say';

sub check_command {
    my ($cmd) = @_;
    my @paths = split(':', $ENV{PATH} || '/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin');
    foreach my $path (@paths) {
        my $full_path = "$path/$cmd";
        return $full_path if -x $full_path;
    }
    return;
}

sub usage {
    say "What is it : Linux file permissions explainer";
    say "Usage      : rights ARGUMENTS";
    say "";
    say "Arguments:";
    say "  Symbolic permissions : rwxr-xr-x, rw-------, r-x--x--x";
    say "  Numeric permissions  : 755, 644, 777, 600, 444";
    say "  File/directory path  : /dev/video0, script.sh, /tmp";
    say "";
    say "Examples:";
    say "  rights 755           # Explain numeric permissions";
    say "  rights rwxr-xr-x     # Explain symbolic permissions";
    say "  rights /dev/video0   # Explain file permissions";
}

sub explain_symbolic_perm {
    my ($perm) = @_;
    my $type   = $perm->{type} // '-';
    my $own_r  = $perm->{own_r};
    my $own_w  = $perm->{own_w};
    my $own_x  = $perm->{own_x};
    my $grp_r  = $perm->{grp_r};
    my $grp_w  = $perm->{grp_w};
    my $grp_x  = $perm->{grp_x};
    my $oth_r  = $perm->{oth_r};
    my $oth_w  = $perm->{oth_w};
    my $oth_x  = $perm->{oth_x};
    my $suffix = $perm->{suffix} // '';

    my $spc_num = 0;
    $spc_num += 4 if $own_x =~ /[sS]/;
    $spc_num += 2 if $grp_x =~ /[sS]/;
    $spc_num += 1 if $oth_x =~ /[tT]/;
    my $own_num = 0;
    $own_num += 4 if $own_r eq 'r';
    $own_num += 2 if $own_w eq 'w';
    $own_num += 1 if $own_x =~ /[xs]/;
    my $grp_num = 0;
    $grp_num += 4 if $grp_r eq 'r';
    $grp_num += 2 if $grp_w eq 'w';
    $grp_num += 1 if $grp_x =~ /[xs]/;
    my $oth_num = 0;
    $oth_num += 4 if $oth_r eq 'r';
    $oth_num += 2 if $oth_w eq 'w';
    $oth_num += 1 if $oth_x =~ /[xt]/;

    print "File type:           ";
    if    ($type eq '-') { say "regular file" }
    elsif ($type eq 'd') { say "directory" }
    elsif ($type eq 'l') { say "symbolic link" }
    elsif ($type eq 'p') { say "named pipe" }
    elsif ($type eq 'c') { say "character device" }
    elsif ($type eq 'b') { say "block device" }
    elsif ($type eq 's') { say "socket" }
    elsif ($type eq '' ) { say "not specified" }

    print "Special bits:        ";
    print (($own_x =~ /[sS]/) ? "SUID (+4), " : "no SUID, " );
    print (($grp_x =~ /[sS]/) ? "SGID (+2), " : "no SGID, " );
    say   (($oth_x =~ /[tT]/) ? "sticky (+1)" : "no sticky" );

    print "Owner permissions:   ";
    print (($own_r eq 'r') ? "read (+4), "  : "no read, " );
    print (($own_w eq 'w') ? "write (+2), " : "no write, " );
    if    ($own_x  eq 'x') { say "execute (+1)" }
    elsif ($own_x  eq 's') { say "execute (+1) with SUID (run as file owner)" }
    elsif ($own_x  eq 'S') { say "no execute but SUID set (run as file owner)" }
    elsif ($own_x  eq '-') { say "no execute" }

    print "Group permissions:   ";
    print (($grp_r eq 'r') ? "read (+4), "  : "no read, " );
    print (($grp_w eq 'w') ? "write (+2), " : "no write, " );
    if    ($grp_x  eq 'x') { say "execute (+1)" }
    elsif ($grp_x  eq 's') { say "execute (+1) with SGID (run as group member)" }
    elsif ($grp_x  eq 'S') { say "no execute but SGID set (run as group member)" }
    elsif ($grp_x  eq '-') { say "no execute" }

    print "Others permissions:  ";
    print (($oth_r eq 'r') ? "read (+4), "  : "no read, " );
    print (($oth_w eq 'w') ? "write (+2), " : "no write, " );
    if    ($oth_x  eq 'x') { say "execute (+1)" }
    elsif ($oth_x  eq 't') { say "execute (+1) with sticky (for directories: only file owner or root can delete files)" }
    elsif ($oth_x  eq 'T') { say "no execute but sticky set (for directories: only file owner or root can delete files)" }
    elsif ($oth_x  eq '-') { say "no execute" }

    print "Suffix:              ";
    if    ($suffix eq '+') { say "ACL present (Access Control Lists)" }
    elsif ($suffix eq '.') { say "SELinux context present" }
    elsif ($suffix eq '' ) { say "not specified" }

    my $symbolic = $type.$own_r.$own_w.$own_x.$grp_r.$grp_w.$grp_x.$oth_r.$oth_w.$oth_x.$suffix;
    print "Symbolic:            $symbolic\n";

    my $numeric  = $spc_num > 0 ? $spc_num.$own_num.$grp_num.$oth_num : $own_num.$grp_num.$oth_num;
    print "Numeric:             $numeric\n";
}

sub explain_numeric_perm {
    my ($num) = @_;
    my ($spc_num, $own_num, $grp_num, $oth_num) = (0, 0, 0, 0);

    if (length($num) == 3) {
        ($own_num, $grp_num, $oth_num) = split //, $num;
    } elsif (length($num) == 4) {
        ($spc_num, $own_num, $grp_num, $oth_num) = split //, $num;
    }

    my %perm = (
        type   => '',
        own_r  => ($own_num & 4) ? 'r' : '-',
        own_w  => ($own_num & 2) ? 'w' : '-',
        own_x  => ($own_num & 1) ? (($spc_num & 4) ? 's' : 'x') : (($spc_num & 4) ? 'S' : '-'),
        grp_r  => ($grp_num & 4) ? 'r' : '-',
        grp_w  => ($grp_num & 2) ? 'w' : '-',
        grp_x  => ($grp_num & 1) ? (($spc_num & 2) ? 's' : 'x') : (($spc_num & 2) ? 'S' : '-'),
        oth_r  => ($oth_num & 4) ? 'r' : '-',
        oth_w  => ($oth_num & 2) ? 'w' : '-',
        oth_x  => ($oth_num & 1) ? (($spc_num & 1) ? 't' : 'x') : (($spc_num & 1) ? 'T' : '-'),
        suffix => '',
    );

    explain_symbolic_perm(\%perm);
}

sub parse_symbolic_perm {
    my ($perm_string) = @_;

    if ($perm_string =~ /^([-dlscbp]?)([r-])([w-])([xsS-])([r-])([w-])([xsS-])([r-])([w-])([xtT-])([+\.]?)$/) {
        return {
            type  => $1,
            own_r => $2, own_w => $3, own_x => $4,
            grp_r => $5, grp_w => $6, grp_x => $7,
            oth_r => $8, oth_w => $9, oth_x => $10,
            suffix => $11
        };
    }
    return undef;
}

sub explain {
    my ($arg) = @_;

    if (-e $arg || -l $arg) {
        my $ls = check_command('ls');
        unless ($ls) {
            say STDERR "ERROR: Program 'ls' is required to check file permissions";
            exit 1;
        }

        my $perm_string = `$ls -ld "$arg" 2>/dev/null`;
        chomp $perm_string;
        $perm_string =~ s/\s.*$//;

        my $perm = parse_symbolic_perm($perm_string);
        if ($perm) {
            explain_symbolic_perm($perm);
        } else {
            say STDERR "ERROR: Cannot parse permissions for $arg";
            exit 1;
        }
    } elsif ($arg =~ /^[0-7]{3,4}$/) {
        explain_numeric_perm($arg);
    } else {
        my $perm = parse_symbolic_perm($arg);
        if ($perm) {
            explain_symbolic_perm($perm);
        } else {
            say STDERR "ERROR: '$arg' is not a valid file, directory, or permission string";
            usage();
            exit 1;
        }
    }
}

sub main {
    for my $i (0..$#ARGV) {
        explain($ARGV[$i]);
        say "" if $i < $#ARGV;
    }
    exit 0;
}

unless (@ARGV) {
    usage();
    exit 1;
}

main();
